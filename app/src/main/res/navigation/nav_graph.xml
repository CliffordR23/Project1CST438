<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/FirstFragment">

    <fragment
        android:id="@+id/FirstFragment"
        android:name="com.example.project_1.FirstFragment"
        android:label="@string/first_fragment_label"
        tools:layout="@layout/fragment_first">

        <action
            android:id="@+id/action_FirstFragment_to_SecondFragment"
            app:destination="@id/SecondFragment" />

        <!-- Go to home and remove login from back stack -->
        <action
            android:id="@+id/action_FirstFragment_to_HomeFragment"
            app:destination="@id/LandingFragment"
            app:popUpTo="@id/FirstFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/SecondFragment"
        android:name="com.example.project_1.SecondFragment"
        android:label="@string/second_fragment_label"
        tools:layout="@layout/fragment_second">

        <action
            android:id="@+id/action_SecondFragment_to_FirstFragment"
            app:destination="@id/FirstFragment" />

        <!-- Go to home and remove login from back stack too -->
        <action
            android:id="@+id/action_SecondFragment_to_HomeFragment"
            app:destination="@id/LandingFragment"
            app:popUpTo="@id/FirstFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/LandingFragment"
        android:name="com.example.project_1.LandingFragment"
        android:label="Landing"
        tools:layout="@layout/fragment_landing">

        <action
            android:id="@+id/action_LandingFragment_to_HomeFragment"
            app:destination="@id/HomeFragment"
            app:popUpTo="@id/LandingFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/HomeFragment"
        android:name="com.example.project_1.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_HomeFragment_to_SavedNumbersFragment"
            app:destination="@id/SavedNumbersFragment" />
    </fragment>

    <fragment
        android:id="@+id/SavedNumbersFragment"
        android:name="com.example.project_1.SavedNumbersFragment"
        android:label="Saved Numbers">
    </fragment>

</navigation>
